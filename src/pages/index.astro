---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = posts[0];
const latest = posts.slice(1, 4);

const usedTopics = new Set(posts.map((p) => p.data.topic).filter(Boolean));
const slugify = (s) => s.toLowerCase().replace(/\s+/g, '-');

const topics = [
  ['Operations', 'when the plan breaks'],
  ['Customer service', 'why the broken load decides the relationship'],
  ['LTL', 'partial-load economics'],
  ['Truckload', 'the true cost of cheap'],
  ['Warehousing', 'what happens between the docks'],
  ['Retail logistics', 'the last mile to the shelf'],
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-white text-af-ink">
    <Header />
    <main>
      <!-- HERO -->
      <section class="bg-af-ink">
        <div class="mx-auto max-w-5xl px-6 py-24 md:py-32">
          <p class="text-xs font-bold uppercase tracking-[0.35em] text-af-green">Armor Freight Journal</p>
          <h1 class="font-display mt-8 max-w-[18ch] text-5xl text-white md:text-8xl">
            Most freight companies measure success by the loads that never had a problem.
          </h1>
          <p class="mt-8 max-w-2xl text-xl font-medium leading-snug text-neutral-400 md:text-2xl">
            Our customers remember us for the ones that did.
          </p>
          {featured && (
            <a href={`/blog/${featured.id}/`}
               class="mt-10 inline-block bg-af-green px-6 py-3 text-sm font-bold uppercase tracking-wider text-af-ink no-underline transition hover:brightness-95">
              Read the Journal →
            </a>
          )}
        </div>
      </section>

      <!-- FEATURED -->
      {featured && (
        <section class="mx-auto max-w-5xl px-6 py-20">
          <div class="flex items-center gap-4 border-b-4 border-af-ink pb-3">
            <span class="text-xs font-bold uppercase tracking-[0.25em] text-af-ink">Featured essay</span>
          </div>
          <a href={`/blog/${featured.id}/`} class="group mt-8 block no-underline">
            {featured.data.topic && (
              <span class="text-xs font-bold uppercase tracking-[0.2em] text-af-green-dark">{featured.data.topic}</span>
            )}
            <h2 class="font-display mt-4 max-w-[16ch] text-4xl text-af-ink transition group-hover:text-af-green-dark md:text-6xl">
              {featured.data.title}
            </h2>
            <p class="mt-6 max-w-2xl text-lg leading-relaxed text-neutral-700">{featured.data.description}</p>
            <div class="mt-6 flex items-center gap-4">
              <span class="text-sm font-bold uppercase tracking-wider text-af-green-dark">Read essay →</span>
              <span class="text-sm text-neutral-500"><FormattedDate date={featured.data.pubDate} /></span>
            </div>
          </a>
        </section>
      )}

      <!-- LATEST -->
      {latest.length > 0 && (
        <section class="mx-auto max-w-5xl px-6 py-20">
          <div class="border-b-4 border-af-ink pb-3">
            <span class="text-xs font-bold uppercase tracking-[0.25em] text-af-ink">Latest thinking</span>
          </div>
          <ul class="mt-8 divide-y divide-neutral-200">
            {latest.map((post) => (
              <li class="py-8 first:pt-2">
                <a href={`/blog/${post.id}/`} class="group block no-underline">
                  {post.data.topic && (
                    <span class="text-xs font-bold uppercase tracking-[0.2em] text-af-green-dark">{post.data.topic}</span>
                  )}
                  <h3 class="font-display mt-2 text-3xl text-af-ink transition group-hover:text-af-green-dark md:text-4xl">{post.data.title}</h3>
                  <p class="mt-3 max-w-2xl text-neutral-700">{post.data.description}</p>
                  <p class="mt-3 text-sm text-neutral-500"><FormattedDate date={post.data.pubDate} /></p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- TOPIC INDEX -->
      <section class="mx-auto max-w-5xl px-6 py-20">
        <div class="flex items-baseline justify-between border-b-4 border-af-ink pb-3">
          <span class="font-display text-2xl text-af-ink md:text-3xl">Browse by topic</span>
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-af-green-dark">The index</span>
        </div>
        <div class="mt-2">
          {topics.map(([name, gloss]) => (
            usedTopics.has(name) ? (
              <a href={`/topics/${slugify(name)}/`} class="group flex items-baseline gap-3 border-b border-neutral-300 py-4 no-underline last:border-b-0">
                <span class="whitespace-nowrap text-lg font-extrabold uppercase tracking-wide text-af-ink group-hover:text-af-green-dark">{name}</span>
                <span class="min-w-6 flex-1 translate-y-[-4px] border-b border-dotted border-neutral-400"></span>
                <span class="whitespace-nowrap text-sm italic text-af-green-dark">{gloss}</span>
              </a>
            ) : (
              <div class="flex items-baseline gap-3 border-b border-neutral-300 py-4 last:border-b-0">
                <span class="whitespace-nowrap text-lg font-extrabold uppercase tracking-wide text-neutral-400">{name}</span>
                <span class="min-w-6 flex-1 translate-y-[-4px] border-b border-dotted border-neutral-300"></span>
                <span class="whitespace-nowrap text-sm italic text-neutral-400">{gloss}</span>
              </div>
            )
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>